# Docker connection (optional — defaults to Unix socket)
DOCKER_HOST=unix:///var/run/docker.sock

# Slack notifier
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Generic webhook notifier
JANITOR_WEBHOOK_URL=your_webhook_url_here
JANITOR_WEBHOOK_TOKEN=your_bearer_token_here   # optional

# Email notifier (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SENDER=janitor@example.com
SMTP_RECIPIENTS=team@example.com
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
